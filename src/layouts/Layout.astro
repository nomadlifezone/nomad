---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Your global companion, locally informed',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f7" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 glass">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href={`${base}/`} class="group flex items-center gap-2">
          <span class="text-3xl">🌍</span>
          <span class="text-2xl font-bold gradient-text group-hover:scale-105 transition-transform">Nomad</span>
        </a>

        <div class="flex items-center gap-8">
          <a href={`${base}/en/guides`} class="text-sm font-semibold text-slate-700 hover:text-purple-600 transition-all hover:scale-105">📚 Guides</a>
          <a href={`${base}/en/tools`} class="text-sm font-semibold text-slate-700 hover:text-purple-600 transition-all hover:scale-105">🛠️ Tools</a>
          <div class="flex items-center gap-3 text-sm border-l border-slate-300 pl-6">
            <a href={`${base}/en`} class="px-3 py-1 rounded-full text-slate-600 hover:bg-white hover:shadow-md transition-all">EN</a>
            <a href={`${base}/zh`} class="px-3 py-1 rounded-full text-slate-600 hover:bg-white hover:shadow-md transition-all">中文</a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 w-full">
      <slot />
    </main>

    <footer class="glass mt-auto border-t border-white/20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="text-center space-y-4">
          <div class="flex justify-center items-center gap-2 text-2xl font-bold">
            <span>🌍</span>
            <span class="gradient-text">Nomad</span>
          </div>
          <p class="text-slate-600 text-sm max-w-md mx-auto">
            Your global companion, locally informed. Explore the world with confidence.
          </p>
          <div class="flex justify-center gap-6 pt-4">
            <a href={`${base}/en/guides`} class="text-slate-600 hover:text-purple-600 transition-colors text-sm font-medium">Guides</a>
            <a href={`${base}/en/tools`} class="text-slate-600 hover:text-purple-600 transition-colors text-sm font-medium">Tools</a>
          </div>
          <p class="text-xs text-slate-500 pt-6">© {new Date().getFullYear()} Nomad. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
