---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
}

const {
  title,
  description = 'Your global companion, locally informed',
  lang = 'en',
} = Astro.props;

const base = import.meta.env.BASE_URL;

// 路径辅助函数：正确拼接 base 和路径
function joinPath(path: string) {
  if (base === '/' || base === '') {
    return path;
  }
  return `${base}${path}`;
}

// 根据语言获取导航文本
const navText = {
  guides: lang === 'zh' ? '📚 攻略' : '📚 Guides',
  tools: lang === 'zh' ? '🛠️ 工具' : '🛠️ Tools',
};

// 语言切换链接
const langPrefix = lang === 'zh' ? '/zh' : '/en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#667eea" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 glass">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href={joinPath('/')} class="group flex items-center gap-2">
          <span class="text-3xl">🌍</span>
          <span class="text-2xl font-bold gradient-text group-hover:scale-105 transition-transform">Nomad</span>
        </a>

        <div class="flex items-center gap-8">
          <a href={joinPath(`${langPrefix}/guides`)} class="text-sm font-semibold text-slate-700 hover:text-purple-600 transition-all hover:scale-105">{navText.guides}</a>
          <a href={joinPath(`${langPrefix}/tools`)} class="text-sm font-semibold text-slate-700 hover:text-purple-600 transition-all hover:scale-105">{navText.tools}</a>
          <div class="flex items-center gap-3 text-sm border-l border-slate-300 pl-6">
            <a 
              href={joinPath('/en')} 
              class={`px-3 py-1.5 rounded-full transition-all font-medium ${
                lang === 'en' 
                  ? 'bg-gradient-to-r from-purple-500 to-purple-600 text-white shadow-lg shadow-purple-500/30' 
                  : 'text-slate-600 hover:bg-white hover:shadow-md'
              }`}
            >
              EN
            </a>
            <a 
              href={joinPath('/zh')} 
              class={`px-3 py-1.5 rounded-full transition-all font-medium ${
                lang === 'zh' 
                  ? 'bg-gradient-to-r from-purple-500 to-purple-600 text-white shadow-lg shadow-purple-500/30' 
                  : 'text-slate-600 hover:bg-white hover:shadow-md'
              }`}
            >
              中文
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 w-full">
      <slot />
    </main>

    <footer class="glass mt-auto border-t border-white/20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="text-center space-y-4">
          <div class="flex justify-center items-center gap-2 text-2xl font-bold">
            <span>🌍</span>
            <span class="gradient-text">Nomad</span>
          </div>
          <p class="text-slate-600 text-sm max-w-md mx-auto">
            Your global companion, locally informed. Explore the world with confidence.
          </p>
          <div class="flex justify-center gap-6 pt-4">
            <a href={joinPath('/en/guides')} class="text-slate-600 hover:text-purple-600 transition-colors text-sm font-medium">Guides</a>
            <a href={joinPath('/en/tools')} class="text-slate-600 hover:text-purple-600 transition-colors text-sm font-medium">Tools</a>
          </div>
          <p class="text-xs text-slate-500 pt-6">© {new Date().getFullYear()} Nomad. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
