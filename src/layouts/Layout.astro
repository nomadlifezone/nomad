---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Your global companion, locally informed',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf9f7" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-paper">
    <header class="border-b border-stone-200 sticky top-0 bg-paper/95 backdrop-blur-sm z-50">
      <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-2xl font-serif font-bold tracking-tight text-ink">Nomad</a>

        <div class="flex items-center gap-6">
          <a href="/en/guides" class="text-sm font-medium text-muted hover:text-accent transition-colors">Guides</a>
          <a href="/en/tools" class="text-sm font-medium text-muted hover:text-accent transition-colors">Tools</a>
          <div class="flex items-center gap-2 text-sm border-l border-stone-200 pl-4">
            <a href="/en" class="text-muted hover:text-ink transition-colors">EN</a>
            <span class="text-stone-300">/</span>
            <a href="/zh" class="text-muted hover:text-ink transition-colors">中文</a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto px-4 py-6 sm:py-10 w-full">
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-auto">
      <div class="max-w-5xl mx-auto px-4 py-8 text-center">
        <p class="text-sm text-muted">© {new Date().getFullYear()} Nomad — Your global companion, locally informed</p>
      </div>
    </footer>
  </body>
</html>
