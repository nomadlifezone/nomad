---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nomad — 走遍全球，立足本地">
  <section class="text-center py-16">
    <h1 class="text-4xl font-bold mb-4">欢迎来到 Nomad</h1>
    <p class="text-xl text-gray-600 mb-8">走遍全球，立足本地</p>
    <div class="flex gap-4 justify-center">
      <a href="/zh/guides" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        浏览攻略
      </a>
      <a href="/zh/tools" class="px-6 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        使用工具
      </a>
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-semibold mb-6">精选攻略</h2>
    <p class="text-gray-600">即将上线：在中国生活、旅居的深度指南。</p>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-semibold mb-6">热门工具</h2>
    <p class="text-gray-600">即将上线：汇率转换、单位换算等实用工具。</p>
  </section>
</Layout>
