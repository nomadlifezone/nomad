---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

// Redirect to Chinese homepage
if (Astro.request.headers.get('accept-language')?.includes('zh') || true) {
  return Astro.redirect(`${base}/zh`);
}
---

<Layout title="Nomad — Your global companion, locally informed">
  <section class="text-center py-16">
    <h1 class="text-4xl font-bold mb-4">Welcome to Nomad</h1>
    <p class="text-xl text-gray-600 mb-8">Your global companion, locally informed</p>
    <div class="flex gap-4 justify-center">
      <a href={`${base}/en/guides`} class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        Explore Guides
      </a>
      <a href={`${base}/en/tools`} class="px-6 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        Browse Tools
      </a>
    </div>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-semibold mb-6">Featured Guides</h2>
    <p class="text-gray-600">Coming soon: In-depth guides for navigating life in China and beyond.</p>
  </section>

  <section class="py-12">
    <h2 class="text-2xl font-semibold mb-6">Popular Tools</h2>
    <p class="text-gray-600">Coming soon: Currency converter, unit converter, and more.</p>
  </section>
</Layout>
