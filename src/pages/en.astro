---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

function joinPath(path: string) {
  if (base === '/' || base === '') return path;
  return `${base}${path}`;
}
---

<Layout title="Nomad — Your global companion, locally informed" lang="en">
  <!-- Hero Section -->
  <section class="text-center py-20 px-4">
    <div class="animate-fade-up">
      <div class="inline-block mb-6">
        <span class="text-7xl animate-float inline-block">🌍</span>
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
        <span class="gradient-text">Your Global Companion</span>
        <br />
        <span class="text-slate-800">Locally Informed</span>
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 mb-10 max-w-2xl mx-auto animate-fade-up animate-delay-200">
        Essential guides and tools for digital nomads and travelers worldwide
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up animate-delay-300">
        <a href={joinPath('/en/guides')} class="btn-primary inline-flex items-center gap-2">
          <span>📚</span>
          <span>Explore Guides</span>
        </a>
        <a href={joinPath('/en/tools')} class="btn-secondary inline-flex items-center gap-2">
          <span>🛠️</span>
          <span>Browse Tools</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 animate-fade-up">
        <span class="gradient-text">✨ Why Choose Nomad?</span>
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="glass rounded-2xl p-8 card-hover-lift animate-fade-up animate-delay-100">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-bold mb-3 text-slate-800">Local Expertise</h3>
          <p class="text-slate-600">In-depth local guides to help you live like a local, anywhere</p>
        </div>
        <div class="glass rounded-2xl p-8 card-hover-lift animate-fade-up animate-delay-200">
          <div class="text-5xl mb-4">📊</div>
          <h3 class="text-xl font-bold mb-3 text-slate-800">Practical Tools</h3>
          <p class="text-slate-600">Currency converters, transit info, and more essential utilities</p>
        </div>
        <div class="glass rounded-2xl p-8 card-hover-lift animate-fade-up animate-delay-300">
          <div class="text-5xl mb-4">🌐</div>
          <h3 class="text-xl font-bold mb-3 text-slate-800">Multi-Language</h3>
          <p class="text-slate-600">Content in English and Chinese for seamless experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Guides Section -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-3xl font-bold">
          <span class="gradient-text">🔥 Popular Guides</span>
        </h2>
        <a href={joinPath('/en/guides')} class="text-purple-600 hover:text-purple-700 font-semibold text-sm hover:underline">
          View All →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <a href={joinPath('/en/guides/how-to-use-alipay-as-foreigner')} class="glass rounded-2xl p-8 card-hover-lift group">
          <div class="text-4xl mb-4">💳</div>
          <h3 class="text-2xl font-bold mb-3 text-slate-800 group-hover:text-purple-600 transition-colors">How to Use Alipay as a Foreigner</h3>
          <p class="text-slate-600 mb-4">Complete guide to setting up and using Alipay with foreign phone number and international bank card</p>
          <div class="flex gap-2 flex-wrap">
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-xs rounded-full font-medium">payment</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full font-medium">alipay</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full font-medium">china</span>
          </div>
        </a>
        <a href={joinPath('/en/guides/china-money-guide')} class="glass rounded-2xl p-8 card-hover-lift group">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="text-2xl font-bold mb-3 text-slate-800 group-hover:text-purple-600 transition-colors">How to Manage Money in China</h3>
          <p class="text-slate-600 mb-4">A comprehensive guide to handling money in China - from currency exchange to mobile payments</p>
          <div class="flex gap-2 flex-wrap">
            <span class="px-3 py-1 bg-yellow-100 text-yellow-700 text-xs rounded-full font-medium">finance</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-xs rounded-full font-medium">payment</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full font-medium">china</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto text-center glass rounded-3xl p-12 animate-fade-up">
      <div class="text-6xl mb-6 animate-float">🚀</div>
      <h2 class="text-4xl font-bold mb-6">
        <span class="gradient-text">Start Your Journey</span>
      </h2>
      <p class="text-xl text-slate-600 mb-8">
        Join thousands of digital nomads exploring local life around the world
      </p>
      <a href={joinPath('/en/guides')} class="btn-primary inline-flex items-center gap-2">
        <span>🌟</span>
        <span>Get Started</span>
      </a>
    </div>
  </section>
</Layout>
