---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryById, getSubcategoryById } from '../../config/categories';

const guides = await getCollection('guides');
const zhGuides = guides.filter(g => g.data.lang === 'zh');
const base = import.meta.env.BASE_URL;

function joinPath(path: string) {
  if (base === '/' || base === '') return path;
  return `${base}${path}`;
}

// 按分类分组攻略
const guidesByCategory = new Map();

categories.forEach(cat => {
  const categoryGuides = zhGuides.filter(g => g.data.category === cat.id);
  if (categoryGuides.length > 0) {
    guidesByCategory.set(cat.id, {
      category: cat,
      guides: categoryGuides,
      // 按子分类再分组
      bySubcategory: new Map()
    });

    // 按子分类分组
    cat.subcategories?.forEach(sub => {
      const subGuides = categoryGuides.filter(g => g.data.subcategory === sub.id);
      if (subGuides.length > 0) {
        guidesByCategory.get(cat.id).bySubcategory.set(sub.id, {
          subcategory: sub,
          guides: subGuides
        });
      }
    });
  }
});

// 获取精选攻略
const featuredGuides = zhGuides.filter(g => g.data.featured).slice(0, 6);
---

<Layout title="攻略 — Nomad" lang="zh">
  <section class="py-8">
    <!-- Header -->
    <div class="text-center mb-16 animate-fade-up">
      <div class="inline-block mb-4">
        <span class="text-6xl animate-float">📚</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="gradient-text">环球旅者的本地生活指南</span>
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto">
        深度攻略，帮助你在任何城市像当地人一样生活
      </p>
    </div>

    <!-- 精选攻略 -->
    {featuredGuides.length > 0 && (
      <div class="mb-20 animate-fade-up">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">⭐</span>
          <h2 class="text-3xl font-bold text-slate-800">精选推荐</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {featuredGuides.map((guide) => {
            const category = getCategoryById(guide.data.category);
            const subcategory = guide.data.subcategory 
              ? getSubcategoryById(guide.data.category, guide.data.subcategory)
              : null;
            
            return (
              <a 
                href={joinPath(`/zh/guides/${guide.id.replace(/\.mdx?$/, '')}`)} 
                class="glass rounded-2xl p-6 card-hover-lift group"
              >
                <div class="flex items-start gap-3 mb-3">
                  <div class="text-3xl">{guide.data.icon}</div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      {subcategory && (
                        <span class="text-xs px-2 py-1 bg-purple-100 text-purple-700 rounded-full font-medium">
                          {subcategory.icon} {subcategory.name.zh}
                        </span>
                      )}
                      {guide.data.difficulty && (
                        <span class="text-xs px-2 py-1 bg-blue-100 text-blue-700 rounded-full">
                          {guide.data.difficulty}
                        </span>
                      )}
                    </div>
                    <h3 class="text-lg font-bold text-slate-800 group-hover:text-purple-600 transition-colors leading-snug">
                      {guide.data.title}
                    </h3>
                  </div>
                </div>
                <p class="text-sm text-slate-600 mb-3 line-clamp-2">{guide.data.description}</p>
                {guide.data.duration && (
                  <div class="text-xs text-slate-500 flex items-center gap-1">
                    <span>⏱️</span>
                    <span>{guide.data.duration}</span>
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- 按分类展示攻略 -->
    {Array.from(guidesByCategory.entries()).map(([categoryId, data], catIndex) => (
      <div class={`mb-20 animate-fade-up animate-delay-${(catIndex + 1) * 100}`}>
        <!-- 分类标题 -->
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">{data.category.icon}</span>
          <div>
            <h2 class="text-3xl font-bold text-slate-800">{data.category.name.zh}</h2>
            {data.category.description && (
              <p class="text-slate-600 mt-1">{data.category.description.zh}</p>
            )}
          </div>
        </div>

        {/* 如果有子分类，按子分类展示 */}
        {data.bySubcategory.size > 0 ? (
          <div class="space-y-12">
            {Array.from(data.bySubcategory.entries()).map(([subId, subData]) => (
              <div>
                <h3 class="text-xl font-bold text-slate-700 mb-4 flex items-center gap-2">
                  <span>{subData.subcategory.icon}</span>
                  <span>{subData.subcategory.name.zh}</span>
                  <span class="text-sm font-normal text-slate-500">({subData.guides.length})</span>
                </h3>
                <div class="grid gap-6 md:grid-cols-2">
                  {subData.guides.map((guide) => (
                    <a 
                      href={joinPath(`/zh/guides/${guide.id.replace(/\.mdx?$/, '')}`)} 
                      class="glass rounded-2xl p-6 card-hover-lift group"
                    >
                      <div class="flex items-start gap-3 mb-3">
                        <div class="text-3xl">{guide.data.icon}</div>
                        <div class="flex-1">
                          <div class="flex items-center gap-2 mb-2">
                            {guide.data.difficulty && (
                              <span class="text-xs px-2 py-1 bg-blue-100 text-blue-700 rounded-full">
                                {guide.data.difficulty}
                              </span>
                            )}
                            {guide.data.location && (
                              <span class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full">
                                📍 {guide.data.location}
                              </span>
                            )}
                          </div>
                          <h4 class="text-lg font-bold text-slate-800 group-hover:text-purple-600 transition-colors leading-snug mb-2">
                            {guide.data.title}
                          </h4>
                        </div>
                      </div>
                      <p class="text-sm text-slate-600 mb-3 line-clamp-2">{guide.data.description}</p>
                      <div class="flex items-center gap-3 text-xs text-slate-500">
                        {guide.data.duration && (
                          <span class="flex items-center gap-1">
                            <span>⏱️</span>
                            <span>{guide.data.duration}</span>
                          </span>
                        )}
                        {guide.data.tags && guide.data.tags.length > 0 && (
                          <div class="flex gap-1 flex-wrap">
                            {guide.data.tags.slice(0, 3).map(tag => (
                              <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded">
                                {tag}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          /* 没有子分类，直接展示所有攻略 */
          <div class="grid gap-6 md:grid-cols-2">
            {data.guides.map((guide) => (
              <a 
                href={joinPath(`/zh/guides/${guide.id.replace(/\.mdx?$/, '')}`)} 
                class="glass rounded-2xl p-6 card-hover-lift group"
              >
                <div class="flex items-start gap-3 mb-3">
                  <div class="text-3xl">{guide.data.icon}</div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      {guide.data.difficulty && (
                        <span class="text-xs px-2 py-1 bg-blue-100 text-blue-700 rounded-full">
                          {guide.data.difficulty}
                        </span>
                      )}
                      {guide.data.location && (
                        <span class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full">
                          📍 {guide.data.location}
                        </span>
                      )}
                    </div>
                    <h4 class="text-lg font-bold text-slate-800 group-hover:text-purple-600 transition-colors leading-snug mb-2">
                      {guide.data.title}
                    </h4>
                  </div>
                </div>
                <p class="text-sm text-slate-600 mb-3 line-clamp-2">{guide.data.description}</p>
                <div class="flex items-center gap-3 text-xs text-slate-500">
                  {guide.data.duration && (
                    <span class="flex items-center gap-1">
                      <span>⏱️</span>
                      <span>{guide.data.duration}</span>
                    </span>
                  )}
                  {guide.data.tags && guide.data.tags.length > 0 && (
                    <div class="flex gap-1 flex-wrap">
                      {guide.data.tags.slice(0, 3).map(tag => (
                        <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    ))}

    {/* 如果没有任何攻略 */}
    {zhGuides.length === 0 && (
      <div class="text-center py-20">
        <div class="glass rounded-3xl p-12 max-w-md mx-auto">
          <div class="text-6xl mb-6">🚧</div>
          <p class="text-xl text-slate-600">攻略正在筹备中，敬请期待！</p>
        </div>
      </div>
    )}

    <!-- CTA -->
    <div class="mt-20 text-center glass rounded-3xl p-12 animate-fade-up animate-delay-400">
      <div class="text-5xl mb-4">✍️</div>
      <h3 class="text-2xl font-bold mb-4 text-slate-800">没找到你需要的攻略？</h3>
      <p class="text-slate-600 mb-6">我们持续更新内容，欢迎提供反馈和建议</p>
      <a href={joinPath('/zh/tools')} class="btn-secondary inline-flex items-center gap-2">
        <span>🛠️</span>
        <span>浏览实用工具</span>
      </a>
    </div>
  </section>
</Layout>
