---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import AdUnit from '../../../components/AdUnit.astro';
import { extractContentByLang, getDifficultyText, getLocalizedString, getLocalizedArray } from '../../../utils/i18n';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  
  // Filter for English files (ID ends with 'en')
  const enGuides = guides
    .filter(g => g.id.endsWith('en'))
    .map(guide => ({
      params: { slug: guide.id.replace(/en$/, '') }, // Remove trailing 'en'
      props: { guide },
    }));
  
  return enGuides;
}

const { guide } = Astro.props;
const lang = 'en';

// Get slug without language suffix for language switching
// alipay-guideen -> alipay-guide
const baseSlug = guide.id.replace(/(zh|en)$/, '');

// Get localized fields
const title = getLocalizedString(guide.data.title, lang);
const description = getLocalizedString(guide.data.description, lang);
const tags = getLocalizedArray(guide.data.tags, lang);
const location = getLocalizedString(guide.data.location, lang);
const duration = getLocalizedString(guide.data.duration, lang);
const difficulty = guide.data.difficulty ? getDifficultyText(guide.data.difficulty, lang) : '';

// Render content
const { Content } = await render(guide);

const siteUrl = 'https://nomad.guide';
const articleUrl = `${siteUrl}/en/guides/${baseSlug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: guide.data.coverImage,
  datePublished: guide.data.publishedAt.toISOString(),
  dateModified: (guide.data.updatedAt || guide.data.publishedAt).toISOString(),
  author: { '@type': 'Organization', name: 'Nomad', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'Nomad', url: siteUrl },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
};
---

<Layout title={`${title} — Nomad`} description={description} lang="en">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="canonical" href={articleUrl} />
    <link rel="alternate" hreflang="en" href={articleUrl} />
    <link rel="alternate" hreflang="zh" href={`${siteUrl}/zh/guides/${baseSlug}`} />
    <link rel="alternate" hreflang="x-default" href={articleUrl} />
  </Fragment>

  <article class="max-w-3xl mx-auto">
    <!-- Cover Image -->
    {guide.data.coverImage && (
      <div class="mb-8 -mx-4 sm:mx-0 animate-fade-up">
        <img 
          src={guide.data.coverImage} 
          alt={title}
          class="w-full h-64 sm:h-96 object-cover sm:rounded-2xl shadow-lg"
          loading="eager"
        />
      </div>
    )}

    <header class="mb-8 animate-fade-up">
      <!-- Icon and category info -->
      {guide.data.icon && (
        <div class="text-5xl mb-4">{guide.data.icon}</div>
      )}
      
      <h1 class="text-4xl font-bold mb-4 gradient-text">{title}</h1>
      <p class="text-lg text-slate-600">{description}</p>
      
      <!-- Meta tags -->
      <div class="flex flex-wrap gap-2 mt-4">
        {difficulty && (
          <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs rounded-full font-medium">
            {difficulty}
          </span>
        )}
        {duration && (
          <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full font-medium">
            ⏱️ {duration}
          </span>
        )}
        {location && (
          <span class="px-3 py-1 bg-purple-100 text-purple-700 text-xs rounded-full font-medium">
            📍 {location}
          </span>
        )}
      </div>
      
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-3">
        {tags && tags.map(tag => (
          <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs rounded-full font-medium">{tag}</span>
        ))}
      </div>
      
      <time class="text-sm text-slate-500 mt-4 block">
        {new Date(guide.data.publishedAt).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        })}
      </time>
    </header>

    <!-- Ad Unit 1: Below Title -->
    <AdUnit slot="1234567890" format="horizontal" className="animate-fade-up animate-delay-100" />

    <div class="prose prose-lg max-w-prose mx-auto animate-fade-up animate-delay-200">
      <Content />
    </div>

    <!-- Ad Unit 2: Bottom of Article -->
    <AdUnit slot="0987654321" format="rectangle" className="animate-fade-up" />
  </article>
</Layout>
