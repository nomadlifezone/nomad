---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categories, getCategoryById, getSubcategoryById } from '../../config/categories';
import GuideCard from '../../components/GuideCard.astro';

const allGuides = await getCollection('guides');
// 过滤出英文文件（ID以'en'结尾）
// Astro会将 alipay-guide.en.md 转换为 alipay-guideen
const guides = allGuides.filter(g => g.id.endsWith('en'));
const lang = 'en';
const base = import.meta.env.BASE_URL;

function joinPath(path: string) {
  if (base === '/' || base === '') return path;
  return `${base}${path}`;
}

// Helper function: Generate guide href (remove language suffix)
function getGuideHref(guideId: string): string {
  // guideId format: alipay-guideen
  // Remove trailing 'zh' or 'en' to get slug
  const slug = guideId.replace(/(zh|en)$/, '');
  return joinPath(`/en/guides/${slug}`);
}

// Group guides by category
const guidesByCategory = new Map();

categories.forEach(cat => {
  const categoryGuides = guides.filter(g => g.data.category === cat.id);
  if (categoryGuides.length > 0) {
    guidesByCategory.set(cat.id, {
      category: cat,
      guides: categoryGuides,
      // Group by subcategory
      bySubcategory: new Map()
    });

    // Group by subcategory
    cat.subcategories?.forEach(sub => {
      const subGuides = categoryGuides.filter(g => g.data.subcategory === sub.id);
      if (subGuides.length > 0) {
        guidesByCategory.get(cat.id).bySubcategory.set(sub.id, {
          subcategory: sub,
          guides: subGuides
        });
      }
    });
  }
});

// Get featured guides
const featuredGuides = guides.filter(g => g.data.featured).slice(0, 6);
---

<Layout title="Guides — Nomad" lang="en">
  <section class="py-8">
    <!-- Header -->
    <div class="text-center mb-16 animate-fade-up">
      <div class="inline-block mb-4">
        <span class="text-6xl animate-float">📚</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="gradient-text">In-Depth Guides for Global Nomads</span>
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto">
        Navigate life as a digital nomad with our comprehensive local guides
      </p>
    </div>

    <!-- Featured Guides -->
    {featuredGuides.length > 0 && (
      <div class="mb-20 animate-fade-up">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">⭐</span>
          <h2 class="text-3xl font-bold text-slate-800">Featured Guides</h2>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {featuredGuides.map((guide) => {
            const subcategory = guide.data.subcategory 
              ? getSubcategoryById(guide.data.category, guide.data.subcategory)
              : null;
            
            return (
              <GuideCard
                guide={guide}
                lang={lang}
                href={getGuideHref(guide.id)}
                showSubcategory={true}
                subcategoryInfo={subcategory ? {
                  icon: subcategory.icon || '',
                  name: subcategory.name.en
                } : undefined}
              />
            );
          })}
        </div>
      </div>
    )}

    <!-- Guides by Category -->
    {Array.from(guidesByCategory.entries()).map(([categoryId, data], catIndex) => (
      <div class={`mb-20 animate-fade-up animate-delay-${(catIndex + 1) * 100}`}>
        <!-- Category Title -->
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">{data.category.icon}</span>
          <div>
            <h2 class="text-3xl font-bold text-slate-800">{data.category.name.en}</h2>
            {data.category.description && (
              <p class="text-slate-600 mt-1">{data.category.description.en}</p>
            )}
          </div>
        </div>

        {/* If has subcategories, display by subcategory */}
        {data.bySubcategory.size > 0 ? (
          <div class="space-y-12">
            {Array.from(data.bySubcategory.entries()).map(([subId, subData]) => (
              <div>
                <h3 class="text-xl font-bold text-slate-700 mb-4 flex items-center gap-2">
                  <span>{subData.subcategory.icon}</span>
                  <span>{subData.subcategory.name.en}</span>
                  <span class="text-sm font-normal text-slate-500">({subData.guides.length})</span>
                </h3>
                <div class="grid gap-6 md:grid-cols-2">
                  {subData.guides.map((guide) => (
                    <GuideCard
                      guide={guide}
                      lang={lang}
                      href={getGuideHref(guide.id)}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          /* No subcategories, display all guides directly */
          <div class="grid gap-6 md:grid-cols-2">
            {data.guides.map((guide) => (
              <GuideCard
                guide={guide}
                lang={lang}
                href={getGuideHref(guide.id)}
              />
            ))}
          </div>
        )}
      </div>
    ))}

    {/* If no guides */}
    {guides.length === 0 && (
      <div class="text-center py-20">
        <div class="glass rounded-3xl p-12 max-w-md mx-auto">
          <div class="text-6xl mb-6">🚧</div>
          <p class="text-xl text-slate-600">Guides coming soon. Stay tuned!</p>
        </div>
      </div>
    )}

    <!-- CTA -->
    <div class="mt-20 text-center glass rounded-3xl p-12 animate-fade-up animate-delay-400">
      <div class="text-5xl mb-4">✍️</div>
      <h3 class="text-2xl font-bold mb-4 text-slate-800">Can't find what you're looking for?</h3>
      <p class="text-slate-600 mb-6">We're constantly adding new content. Check out our tools or submit feedback</p>
      <a href={joinPath('/en/tools')} class="btn-secondary inline-flex items-center gap-2">
        <span>🛠️</span>
        <span>Browse Tools</span>
      </a>
    </div>
  </section>
</Layout>
