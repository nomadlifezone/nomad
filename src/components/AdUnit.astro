---
/**
 * Google AdSense 广告单元组件
 * @param slot - 广告位 ID (需要在 AdSense 后台创建)
 * @param format - 广告格式: 'auto' | 'rectangle' | 'horizontal' | 'vertical'
 * @param style - 自定义样式
 */

interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  style?: string;
  className?: string;
}

const { 
  slot, 
  format = 'auto',
  style = 'display:block',
  className = ''
} = Astro.props;

// 根据格式设置样式
const formatStyles = {
  auto: 'display:block',
  rectangle: 'display:inline-block;width:300px;height:250px',
  horizontal: 'display:block',
  vertical: 'display:inline-block;width:160px;height:600px'
};

const adStyle = style || formatStyles[format];
---

<!-- Google AdSense 广告单元 -->
<div class={`ad-container my-8 ${className}`}>
  <ins 
    class="adsbygoogle"
    style={adStyle}
    data-ad-client="ca-pub-8394297244844946"
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
</div>

<script>
  // 初始化广告
  if (typeof window !== 'undefined') {
    try {
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    } catch (e) {
      console.error('AdSense error:', e);
    }
  }
</script>

<style>
  .ad-container {
    text-align: center;
    margin: 2rem auto;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 0.5rem;
    border: 1px dashed rgba(148, 163, 184, 0.3);
  }

  .ad-container::before {
    content: 'Advertisement';
    display: block;
    font-size: 0.75rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .ad-container {
      margin: 1.5rem auto;
      padding: 0.75rem;
    }
  }
</style>
