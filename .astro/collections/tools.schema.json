{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "en",
        "zh"
      ]
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "lang",
    "category",
    "tags",
    "publishedAt"
  ]
}